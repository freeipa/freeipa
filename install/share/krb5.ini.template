[libdefaults]
        default_realm = $REALM
        dns_lookup_kdc = true

[realms]
        $REALM = {
                admin_server = $FQDN
                kdc = $FQDN
                master_kdc = $FQDN
                default_domain = $REALM
        }

[domain_realm]
        .$DOMAIN = $REALM
        $DOMAIN = $REALM

