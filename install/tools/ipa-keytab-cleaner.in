"""
Utility to help periodically cleanup keytab and obsolete KVNOs
config files are created when starting krb5kdc, referenced through
systemd service template and then processed here.
"""

import argparse
import os

from ipaplatform.paths import paths
from ipapython import ipautil
from ipapython.krb5util import KeytabDeletion

if __name__ == "__main__":
    parser = argparse.ArgumentParser(
        description='Remove KVNO keypairs from keytab'
    )
    parser.add_argument(
        "filename", type=str, help="Name of the config file"
    )
    args = parser.parse_args()

    filepath = os.path.join(paths.IPA_KEYTAB_CLEANER_CONF_DIR, args.filename)
    print("Running keytab cleaner with config: %s" % filepath)

    config = KeytabDeletion.from_file(filepath)

    ipautil.run(
        [
            paths.KADMIN_LOCAL,
            "ktremove",
            "-k",
            config.filepath,
            config.principal,
            str(config.kvno),
        ]
    )

    try:
        os.remove(filepath)
    except FileNotFoundError:
        pass
