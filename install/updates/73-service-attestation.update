add:aci: (targetattr = "ipakrbserviceattestationkey || ipakrbserviceattestationtype")(targattrfilters="add=objectclass:(objectclass=ipakrbserviceattestation)")(version 3.0;acl "permission:Attestation:Services can manage own attestation keys";allow (write) userdn = "ldap:///self";)
