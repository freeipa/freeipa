"\n"
"    ipa ca-disable puppet\n"

msgid ""
"\n"
"  Re-enable a CA (requires permission \"System: Modify CA\"):\n"
"\n"
"    ipa ca-enable puppet\n"
msgstr ""
"\n"
"  Re-ativar uma CA (requer permissão \"System: Modify CA\"):\n"
"\n"
"    ipa ca-enable puppet\n"

msgid ""
"\n"
"  Delete a CA (requires permission \"System: Delete CA\"; also requires\n"
"  CA to be disabled first):\n"
"\n"
"    ipa ca-del puppet\n"
msgstr ""
"\n"
"  Apagar uma CA (requer permissão \"System: Delete CA\"; também requer\n"
"  que a CA seja desativada primeiro):\n"
"\n"
"    ipa ca-del puppet\n"

