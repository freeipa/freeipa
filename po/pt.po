"curl   -H \"Content-Type:application/json\"          -H \"Accept:application/"
"json\" -H \"Accept-Language:en\"        --negotiate -u :          --cacert /"
"etc/ipa/ca.crt           -d  @batch_request.json -X POST       http://"
"localhost:8888/ipa/json\n"
