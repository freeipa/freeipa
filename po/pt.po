msgid "Trusted domain did not return a unique object"
msgstr "Domínio de confiança não retornou um objeto único"

msgid "Trusted domain did not return a valid SID for the object"
msgstr "Domínio de confiança não retornou um SID válido para o objeto"

msgid "trusted domain user not found"
msgstr "utilizador de domínio de confiança não encontrado"

msgid "Cannot retrieve trusted domain GC list"
msgstr "Não pode recuperar lista GC de domínio de confiança"

msgid "CIFS credentials object"
msgstr "Objeto de credenciais CIFS"

#, python-format
msgid "CIFS server %(host)s denied your credentials"
msgstr "O servidor CIFS %(host)s negou as suas credenciais"

#, python-format
msgid "Cannot establish LSA connection to %(host)s. Is CIFS server running?"
msgstr ""
"Não pode estabelecer ligação LSA a %(host)s. O servidor CIFS está a correr?"

#, python-format
msgid ""
"the IPA server and the remote domain cannot share the same NetBIOS name: %s"
msgstr ""
"o servidor IPA e o domínio remoto não podem partilhar o mesmo nome de "
"NetBIOS: %s"

#, python-brace-format
msgid ""
"There is already a trust to {ipa_domain} with unsupported type {trust_type}. "
"Please remove it manually on AD DC side."
msgstr ""
"Já existe uma confiança para {ipa_domain} com tipo não suportado {trust_type}"
". Por favor remova-a manualmente no lado do AD DC."

#, python-format
msgid ""
"IPA master denied trust validation requests from AD DC %(count)d times. Most "
"likely AD DC contacted a replica that has no trust information replicated "
"yet. Additionally, please check that AD DNS is able to resolve %(records)s "
"SRV records to the correct IPA server."
msgstr ""
"O mestre IPA negou pedidos de validação de confiança de AD DC %(count)d "
"vezes. Provavelmente o AD DC contactou uma réplica que não tem informação de "
"confiança ainda replicada. Também, por favor verifique que o DNS AD é capaz "
"de resolver registos SRV %(records)s para o servidor IPA correto."

msgid "Credentials"
msgstr "Credenciais"

msgid "Missing credentials for cross-forest communication"
msgstr "Credenciais em falta para comunicação inter-florestal"

msgid ""
"Non-Kerberos user name was specified, please provide user@REALM variant "
"instead"
msgstr ""
"Foi especificado nome de utilizador não-Kerberos, por favor forneça a "
"variante utilizador@REINO em vez disto"

