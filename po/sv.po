#: ipaserver/plugins/internal.py:198
msgid "External Identity Provider"
msgstr "Extern identitetsleverantör"

#: ipaserver/plugins/internal.py:199 ipaserver/plugins/internal.py:1229
msgid "Passkey"
msgstr "Passnyckel"

#: ipaserver/plugins/internal.py:200
msgid "Disable per-user override"
msgstr "Inaktivera överskrivning per användare"

#: ipaserver/plugins/internal.py:201
msgid ""
"<p>Per-user setting, overwrites the global setting if any option is checked."
"</p><p><strong>Password + Two-factor:</strong> LDAP and Kerberos allow "
"authentication with either one of the authentication types but Kerberos uses "
"pre-authentication method which requires to use armor ccache.</"
"p><p><strong>RADIUS with another type:</strong> Kerberos always use RADIUS, "
"but LDAP never does. LDAP only recognize the password and two-factor "
"authentication options.</p>"
msgstr ""
"<p>Inställning per användare, skriver över den globala inställningen om "
"något alternativ är markerat.</p><p><strong>Lösenord + "
"tvåfaktorsautentisering:</strong> LDAP och Kerberos tillåter autentisering "
"med någon av autentiseringstyperna, men Kerberos använder en "
"förhandsautentiseringsmetod som kräver användning av armor ccache.</p><p>"
"<strong>RADIUS med en annan typ:</strong> Kerberos använder alltid RADIUS, "
"men LDAP gör det aldrig. LDAP känner endast igen lösenords- och "
"tvåfaktorsautentiseringsalternativen.</p>"

